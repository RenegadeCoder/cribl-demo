<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Project_Duration__c</fullName>
    <externalId>false</externalId>
    <formula>BLANKVALUE( Go_Live_Date__c , TODAY() ) -  Kick_Off_Call_Date__c</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <inlineHelpText>Days between the Kick Off Call and the Go Live Date (or today, if not live yet)</inlineHelpText>
    <label>Project Duration (Days)</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
